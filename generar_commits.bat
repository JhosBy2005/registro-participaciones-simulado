@echo off
setlocal
chcp 65001 >nul
set "BAT_PATH=%~f0"
set "BAT_ARGS=%*"
powershell -NoProfile -ExecutionPolicy Bypass -Command "$p=$env:BAT_PATH; $raw=[System.IO.File]::ReadAllText($p,[System.Text.Encoding]::UTF8); $m=[regex]::Match($raw,'(?ms)^# POWERSHELL-BEGIN\r?\n(.*?)\r?\n# POWERSHELL-END'); if(-not $m.Success){throw 'No se encontro el bloque PowerShell del .bat.'}; Invoke-Expression $m.Groups[1].Value"
set "ERR=%ERRORLEVEL%"
if not "%ERR%"=="0" (
  echo %* | findstr /C:"--no-pause" >nul
  if errorlevel 1 pause
)
exit /b %ERR%
# POWERSHELL-BEGIN
$ErrorActionPreference = 'Stop'

function Parse-BatArgs([string]$rawArgs) {
    if ([string]::IsNullOrWhiteSpace($rawArgs)) { return @() }
    $matches = [regex]::Matches($rawArgs, '"([^"]*)"|(\S+)')
    $items = New-Object System.Collections.Generic.List[string]
    foreach ($m in $matches) {
        if ($m.Groups[1].Success) { $items.Add($m.Groups[1].Value) } else { $items.Add($m.Groups[2].Value) }
    }
    return $items.ToArray()
}

function Find-GitExe {
    $cmd = Get-Command git.exe -ErrorAction SilentlyContinue
    if ($cmd -and $cmd.Source) { return $cmd.Source }

    $candidates = New-Object System.Collections.Generic.List[string]
    $programFiles = [Environment]::GetEnvironmentVariable('ProgramFiles')
    $programFilesX86 = [Environment]::GetEnvironmentVariable('ProgramFiles(x86)')
    $localAppData = [Environment]::GetEnvironmentVariable('LOCALAPPDATA')

    if ($programFiles) { $candidates.Add((Join-Path $programFiles 'Git\cmd\git.exe')) }
    if ($programFilesX86) { $candidates.Add((Join-Path $programFilesX86 'Git\cmd\git.exe')) }
    if ($localAppData) {
        $githubDesktopPattern = Join-Path $localAppData 'GitHubDesktop\app-*\resources\app\git\cmd\git.exe'
        Get-ChildItem -Path $githubDesktopPattern -ErrorAction SilentlyContinue |
            Sort-Object LastWriteTime -Descending |
            ForEach-Object { $candidates.Add($_.FullName) }
    }

    foreach ($candidate in $candidates) {
        if ($candidate -and (Test-Path -LiteralPath $candidate)) { return $candidate }
    }

    throw 'No se encontro git. Instala Git desde https://git-scm.com o abre GitHub Desktop.'
}

function Invoke-Git([string[]]$GitArgs, [switch]$AllowFailure, [switch]$Quiet) {
    if ($script:RepoRoot) { Clear-StaleGitLock $script:RepoRoot -Silent }

    if ($Quiet) {
        $output = & $script:GitExe @GitArgs 2>&1
    } else {
        & $script:GitExe @GitArgs
        $output = $null
    }
    $code = $LASTEXITCODE
    if ($script:RepoRoot) { Clear-StaleGitLock $script:RepoRoot -Silent }

    if ($code -ne 0 -and -not $AllowFailure) {
        $shown = ($GitArgs -join ' ')
        if ($output) { throw "Git fallo ejecutando: git $shown`n$output" }
        throw "Git fallo ejecutando: git $shown"
    }
    return [pscustomobject]@{ Code = $code; Output = $output }
}

function Set-GitConfigValue([string]$Key, [string]$Value) {
    Invoke-Git @('config', $Key, $Value) | Out-Null
}

function Restore-GitConfig([string]$Name, [string]$Email) {
    if ([string]::IsNullOrWhiteSpace($Name)) {
        Invoke-Git @('config', '--unset', 'user.name') -AllowFailure -Quiet | Out-Null
    } else {
        Set-GitConfigValue 'user.name' $Name
    }

    if ([string]::IsNullOrWhiteSpace($Email)) {
        Invoke-Git @('config', '--unset', 'user.email') -AllowFailure -Quiet | Out-Null
    } else {
        Set-GitConfigValue 'user.email' $Email
    }
}

function Resolve-RepoRoot([string]$ScriptDirectory) {
    Push-Location $ScriptDirectory
    try {
        $inside = Invoke-Git @('rev-parse', '--is-inside-work-tree') -Quiet -AllowFailure
        if ($inside.Code -ne 0) { throw 'No estas dentro de un repositorio git.' }
        $root = (& $script:GitExe rev-parse --show-toplevel 2>$null)
        if ($LASTEXITCODE -ne 0 -or [string]::IsNullOrWhiteSpace($root)) { throw 'No se pudo resolver la raiz del repositorio.' }
        return $root.Trim()
    } finally {
        Pop-Location
    }
}

function Clear-StaleGitLock([string]$RepoRoot, [switch]$Silent) {
    $lock = Join-Path $RepoRoot '.git\index.lock'
    if (-not (Test-Path -LiteralPath $lock)) { return }

    $gitProcesses = @(Get-Process git -ErrorAction SilentlyContinue)
    if ($gitProcesses.Count -gt 0) {
        throw "Existe .git\index.lock y hay procesos git activos. Cierra Git/GitHub Desktop e intenta de nuevo. Lock: $lock"
    }

    Remove-Item -LiteralPath $lock -Force
    if (-not $Silent) { Write-Host '[OK] Lock antiguo de Git eliminado.' }
}

function Get-OriginalPayload([string]$Raw) {
    $marker = '::ORIGINAL-GENERAR-COMMITS-BEGIN'
    $idx = $Raw.LastIndexOf($marker, [System.StringComparison]::Ordinal)
    if ($idx -lt 0) { throw 'No se encontro el payload original dentro del .bat.' }
    return $Raw.Substring($idx + $marker.Length)
}

function Convert-OriginalBatchToActions([string]$OriginalBatch) {
    $actions = New-Object System.Collections.Generic.List[object]
    $lines = $OriginalBatch -split "\r?\n"

    foreach ($line in $lines) {
        if ($line -match '^\s*echo\s+===\s*(.+?)\s*===\s*$') {
            $actions.Add([pscustomobject]@{ Type = 'section'; Text = $matches[1] })
            continue
        }

        if ($line -match '^\s*"?!GIT!"?\s+config\s+user\.name\s+"([^"]*)"\s*$') {
            $actions.Add([pscustomobject]@{ Type = 'configName'; Value = $matches[1] })
            continue
        }

        if ($line -match '^\s*"?!GIT!"?\s+config\s+user\.email\s+"([^"]*)"\s*$') {
            $actions.Add([pscustomobject]@{ Type = 'configEmail'; Value = $matches[1] })
            continue
        }

        $pathMatch = [regex]::Match($line, "WriteAllText\('%CD%\\([^']+)'")
        $base64Prefix = "FromBase64String('"
        $base64Start = $line.IndexOf($base64Prefix)
        if ($pathMatch.Success -and $base64Start -ge 0) {
            $base64Start += $base64Prefix.Length
            $base64End = $line.IndexOf("'", $base64Start)
            if ($base64End -gt $base64Start) {
                $actions.Add([pscustomobject]@{
                    Type = 'write'
                    Path = $pathMatch.Groups[1].Value
                    Base64 = $line.Substring($base64Start, $base64End - $base64Start)
                })
                continue
            }
        }

        if ($line -match '^\s*"?!GIT!"?\s+add\s+(.+?)\s*$') {
            $path = $matches[1].Trim('"')
            $actions.Add([pscustomobject]@{ Type = 'add'; Path = $path })
            continue
        }

        if ($line -match '^\s*"?!GIT!"?\s+commit\s+-m\s+"([^"]+)"\s*$') {
            $actions.Add([pscustomobject]@{ Type = 'commit'; Message = $matches[1] })
            continue
        }
    }

    return $actions
}

function Write-PayloadFile([string]$RepoRoot, [string]$RelativePath, [string]$Base64) {
    $cleanRelative = $RelativePath.TrimStart('\', '/') -replace '\\', '/'
    $fullPath = Join-Path $RepoRoot $cleanRelative
    $directory = Split-Path -Parent $fullPath
    if ($directory -and -not (Test-Path -LiteralPath $directory)) {
        New-Item -ItemType Directory -Path $directory | Out-Null
    }
    [System.IO.File]::WriteAllBytes($fullPath, [Convert]::FromBase64String($Base64))
}

$batPath = [Environment]::GetEnvironmentVariable('BAT_PATH')
if ([string]::IsNullOrWhiteSpace($batPath)) { throw 'BAT_PATH no esta definido.' }
$batArgs = Parse-BatArgs ([Environment]::GetEnvironmentVariable('BAT_ARGS'))
$dryRun = $batArgs -contains '--dry-run'
$noPause = $batArgs -contains '--no-pause'

$script:GitExe = Find-GitExe
$scriptDir = Split-Path -Parent $batPath
$repoRoot = Resolve-RepoRoot $scriptDir
$script:RepoRoot = $repoRoot

Write-Host '============================================'
Write-Host '  GENERADOR DE COMMITS - FAKEJOB DETECTOR'
Write-Host '============================================'
Write-Host "[OK] Git encontrado: $script:GitExe"
Write-Host "[OK] Repositorio: $repoRoot"

$raw = [System.IO.File]::ReadAllText($batPath, [System.Text.Encoding]::UTF8)
$original = Get-OriginalPayload $raw
$actions = Convert-OriginalBatchToActions $original
$writeCount = @($actions | Where-Object Type -eq 'write').Count
$commitCountExpected = @($actions | Where-Object Type -eq 'commit').Count

if ($writeCount -eq 0 -or $commitCountExpected -eq 0) {
    throw 'No se pudieron extraer escrituras/commits del .bat original.'
}

if ($dryRun) {
    $decodedBytes = 0
    foreach ($writeAction in @($actions | Where-Object Type -eq 'write')) {
        $decodedBytes += [Convert]::FromBase64String($writeAction.Base64).Length
    }
    Write-Host "[DRY-RUN] Payload OK: $writeCount escrituras y $commitCountExpected commits detectados."
    Write-Host "[DRY-RUN] Base64 OK: $decodedBytes bytes decodificados en memoria."
    Write-Host '[DRY-RUN] No se modifico ningun archivo ni se genero ningun commit.'
    exit 0
}

Clear-StaleGitLock $repoRoot
Push-Location $repoRoot
$originalName = (Invoke-Git @('config', '--get', 'user.name') -AllowFailure -Quiet).Output
$originalEmail = (Invoke-Git @('config', '--get', 'user.email') -AllowFailure -Quiet).Output
$createdCommits = 0

try {
    if (-not (Test-Path -LiteralPath (Join-Path $repoRoot 'css'))) { New-Item -ItemType Directory -Path (Join-Path $repoRoot 'css') | Out-Null }
    if (-not (Test-Path -LiteralPath (Join-Path $repoRoot 'js'))) { New-Item -ItemType Directory -Path (Join-Path $repoRoot 'js') | Out-Null }

    foreach ($action in $actions) {
        switch ($action.Type) {
            'section' {
                Write-Host ''
                Write-Host "=== $($action.Text) ==="
            }
            'configName' {
                Set-GitConfigValue 'user.name' $action.Value
            }
            'configEmail' {
                Set-GitConfigValue 'user.email' $action.Value
            }
            'write' {
                Write-PayloadFile $repoRoot $action.Path $action.Base64
            }
            'add' {
                Invoke-Git @('add', '--', ($action.Path -replace '\\', '/')) | Out-Null
            }
            'commit' {
                $diff = Invoke-Git @('diff', '--cached', '--quiet', '--exit-code') -AllowFailure -Quiet
                $diffCode = $diff.Code
                if ($diffCode -eq 0) {
                    Write-Host "[SKIP] Sin cambios staged para: $($action.Message)"
                } elseif ($diffCode -eq 1) {
                    Invoke-Git @('commit', '-m', $action.Message) | Out-Null
                    $createdCommits++
                    Write-Host "[OK] $($action.Message)"
                } else {
                    throw 'No se pudo revisar el diff staged antes del commit.'
                }
            }
        }
    }
} finally {
    Restore-GitConfig $originalName $originalEmail
    Pop-Location
}

Write-Host ''
Write-Host '============================================'
Write-Host '  RESUMEN DE COMMITS'
Write-Host '============================================'
Push-Location $repoRoot
try {
    Invoke-Git @('log', '--oneline', '-22') | Out-Null
    Write-Host ''
    $push = Read-Host 'Hacer push ahora? (s/n)'
    if ($push -match '^[sS]$') {
        $pushResult = Invoke-Git @('push') -AllowFailure
        if ($pushResult.Code -eq 0) { Write-Host '[OK] Push exitoso.' } else { Write-Host '[WARN] Fallo el push. Hazlo desde GitHub Desktop o usa: git push --set-upstream origin main' }
    } else {
        Write-Host 'Push omitido. Usa: git push'
    }
} finally {
    Pop-Location
}

Write-Host ''
Write-Host "LISTO. $createdCommits commits generados."
if (-not $noPause) { Read-Host 'Presiona Enter para cerrar' | Out-Null }
# POWERSHELL-END
